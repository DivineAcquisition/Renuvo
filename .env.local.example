# ============================================================================
# SUPABASE
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# STRIPE  (Connect — tenants connect their own accounts)  [Prompt 13+]
# ============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================================================
# TELNYX  (A2P SMS)  [Prompt 15+]
# ============================================================================
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PUBLIC_KEY=
# A2P 10DLC: "true" in dev/staging uses FREE mock brands/campaigns that
# auto-approve (no fees, no TCR review). NEVER set true in production.
A2P_MOCK_MODE=
# Set to "true" to allow production sends on verified numbers BEFORE the Renuvo
# A2P 10DLC campaigns are approved. Leave unset/false once campaigns are live.
TELNYX_ALLOW_UNREGISTERED=

# ============================================================================
# ANTHROPIC  (agent message generation)  [Prompt 18+]
# ============================================================================
ANTHROPIC_API_KEY=

# ============================================================================
# OBSERVABILITY — Sentry (optional; inert until DSN is set)  [Prompt 39]
# ============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Dedicated HMAC key for A2P consent proof (falls back to service-role key)
CONSENT_HMAC_KEY=

# WIN-BACK & REACTIVATION — bring churned customers back  [Prompt 44]
# Ships OFF; flip per-env when ready. Per-org enable also lives in Settings → Controls.
WINBACK_ENABLED=false

# CUSTOMER PORTAL — passwordless homeowner self-service  [Prompt 46]
# HMAC key for magic-link + session tokens (falls back to CONSENT_HMAC_KEY / service role)
PORTAL_TOKEN_SECRET=
# The portal subdomain (account.renuvo.io). Falls back to account.<NEXT_PUBLIC_ROOT_DOMAIN>.
NEXT_PUBLIC_PORTAL_URL=https://account.renuvo.io

# ============================================================================
# EMAIL CHANNEL — Resend, shared authenticated subdomain  [Prompt 42]
# Send-only. Ships OFF until a tenant wants it. CAN-SPAM (not A2P).
# ============================================================================
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM_DOMAIN=mail.renuvo.io
EMAIL_CHANNEL_ENABLED=false
# From address for platform → owner notification emails (sent via Resend)
RENUVO_FROM_EMAIL=Renuvo <notifications@renuvo.io>
# Mirror the flag to the client so capture/customer UIs can show email controls
NEXT_PUBLIC_EMAIL_CHANNEL_ENABLED=false

# ============================================================================
# GOOGLE CALENDAR  (optional, feature-flagged per org)  [Prompt 15]
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.renuvo.io/api/calendar/google/callback
ENCRYPTION_KEY=   # 32-byte hex (64 chars) for AES-256-GCM token encryption

# ============================================================================
# CRON  (Vercel cron → /api/cron/scheduler)  [Prompt 21]
# ============================================================================
# Vercel sends this as `Authorization: Bearer ${CRON_SECRET}` on scheduled calls.
CRON_SECRET=

# ============================================================================
# STRIPE — PLATFORM REVENUE SHARE  (optional)  [Prompt 20]
# ============================================================================
# Application fee % taken on each recurring charge (e.g. 10). Omit for none.
STRIPE_APP_FEE_PERCENT=

# ============================================================================
# APP / DOMAINS
# ============================================================================
NEXT_PUBLIC_APP_URL=https://app.renuvo.io
NEXT_PUBLIC_CAPTURE_URL=https://r.renuvo.io
NEXT_PUBLIC_MARKETING_URL=https://renuvo.io
NEXT_PUBLIC_ROOT_DOMAIN=renuvo.io
